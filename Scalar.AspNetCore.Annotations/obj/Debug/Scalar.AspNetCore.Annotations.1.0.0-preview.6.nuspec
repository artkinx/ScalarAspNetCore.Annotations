<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>Scalar.AspNetCore.Annotations</id>
    <version>1.0.0-preview.6</version>
    <authors>Adunbi Moses</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <readme>README.md</readme>
    <description>Declarative attributes for configuring Scalar OpenAPI documentation in .NET and Swashbuckle.</description>
    <tags>scalar openapi swagger swashbuckle aspnetcore api</tags>
    <repository type="git" url="https://github.com/artkinx/Scalar.AspNetCore.Annotations" />
    <dependencies>
      <group targetFramework="net10.0">
        <dependency id="Microsoft.AspNetCore.OpenApi" version="9.0.16" exclude="Build,Analyzers" />
        <dependency id="Swashbuckle.AspNetCore.SwaggerGen" version="9.0.6" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net8.0">
        <dependency id="Microsoft.AspNetCore.OpenApi" version="8.0.27" exclude="Build,Analyzers" />
        <dependency id="Swashbuckle.AspNetCore.SwaggerGen" version="8.1.4" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net9.0">
        <dependency id="Microsoft.AspNetCore.OpenApi" version="9.0.16" exclude="Build,Analyzers" />
        <dependency id="Swashbuckle.AspNetCore.SwaggerGen" version="9.0.6" exclude="Build,Analyzers" />
      </group>
    </dependencies>
    <frameworkReferences>
      <group targetFramework="net10.0">
        <frameworkReference name="Microsoft.AspNetCore.App" />
      </group>
      <group targetFramework="net8.0">
        <frameworkReference name="Microsoft.AspNetCore.App" />
      </group>
      <group targetFramework="net9.0">
        <frameworkReference name="Microsoft.AspNetCore.App" />
      </group>
    </frameworkReferences>
  </metadata>
