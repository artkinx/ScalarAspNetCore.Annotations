    <file src="C:\projects\priv\Scalar.AspNetCore.Annotations\Scalar.AspNetCore.Annotations\bin\Debug\net10.0\Scalar.AspNetCore.Annotations.xml" target="lib\net10.0\Scalar.AspNetCore.Annotations.xml" />
    <file src="C:\projects\priv\Scalar.AspNetCore.Annotations\Scalar.AspNetCore.Annotations\bin\Debug\net8.0\Scalar.AspNetCore.Annotations.dll" target="lib\net8.0\Scalar.AspNetCore.Annotations.dll" />
    <file src="C:\projects\priv\Scalar.AspNetCore.Annotations\Scalar.AspNetCore.Annotations\bin\Debug\net8.0\Scalar.AspNetCore.Annotations.xml" target="lib\net8.0\Scalar.AspNetCore.Annotations.xml" />
    <file src="C:\projects\priv\Scalar.AspNetCore.Annotations\Scalar.AspNetCore.Annotations\bin\Debug\net9.0\Scalar.AspNetCore.Annotations.dll" target="lib\net9.0\Scalar.AspNetCore.Annotations.dll" />
